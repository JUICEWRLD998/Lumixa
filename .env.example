# ─── TxLINE / TxODDS ───────────────────────────────────────────────
TXLINE_BASE=https://txline.txodds.com
TXLINE_DEV_BASE=https://txline-dev.txodds.com

# ─── Solana (devnet) ───────────────────────────────────────────────
SOLANA_CLUSTER=devnet
SOLANA_RPC=https://api.devnet.solana.com
WALLET_SECRET=                # base58-encoded devnet keypair secret

# ─── Subscription / activation ─────────────────────────────────────
SERVICE_LEVEL_ID=1            # WC free tier (1 = 60s delay, 12 = real-time)
DURATION_WEEKS=4
SELECTED_LEAGUES=worldcup
TXLINE_JWT=                   # filled at runtime by ingest guest-auth
TXLINE_API_TOKEN=            # filled after on-chain subscribe + activation

# ─── Narration (OpenRouter → Gemini) — Phase 3, optional ───────────
OPENROUTER_API_KEY=
OPENROUTER_BASE=https://openrouter.ai/api/v1
NARRATION_MODEL=google/gemini-2.5-flash
