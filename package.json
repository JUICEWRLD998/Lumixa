{
  "name": "lumixa",
  "version": "0.0.0",
  "private": true,
  "description": "Lumixa — the world's first un-fakeable, autonomous sports-trading agent.",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck && tsc --noEmit -p scripts/tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "record": "tsx scripts/record-live.ts",
    "replay:check": "tsx scripts/replay-check.ts",
    "backtest": "tsx scripts/backtest.ts"
  },
  "dependencies": {
    "@lumixa/chain": "workspace:*",
    "@lumixa/core": "workspace:*",
    "@lumixa/engine": "workspace:*",
    "@lumixa/ingest": "workspace:*",
    "@lumixa/replay": "workspace:*",
    "@lumixa/trader": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
